algoritmo "nota"
// Autor : Eloísa e Gustavo
// Data : 14/04/2026
// Seçăo de Declaraçőes 
// F9 (executar o meu código)
var
  idade: real
  
inicio
// Seçăo de Comandos 
 escreva  ("Insira a sua idade: ")
 leia (idade)
 
      se (idade < 5) ou (idade >= 65) entao
      escreval ("Entrada gratuita")
      senao
      escreval ("Entrada paga")
      fimse
fimalgoritmo
